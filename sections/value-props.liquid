<section class="value-props" id="about">
  <div class="container">
    <div class="vp-intro">
      <div class="vp-intro-copy rv">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>
      <div class="vp-intro-img rv d1">
        {% if section.settings.image %}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image.alt }}" loading="lazy">
        {% else %}
          <img src="https://eatboldbar.com/cdn/shop/files/2025_03_23_BOLD_05.jpg?v=1743726302&width=900" alt="Bold Bar lifestyle" loading="lazy">
        {% endif %}
      </div>
    </div>
    <div class="stat-cards">
      {% for block in section.blocks %}
        <div class="stat-card rv {% if forloop.index > 1 %}d{{ forloop.index | minus: 1 }}{% endif %}" {{ block.shopify_attributes }}>
          <div class="ghost-idx">0{{ forloop.index }}</div>
          <div class="stat-num">{{ block.settings.number }}</div>
          <div class="stat-label">{{ block.settings.label }}</div>
          <div class="stat-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Props",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Performance Meets Clean Ingredients"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We built Bold Bar for people who read labels. Real food, real energy, no compromises. Every bar delivers functional protein and natural caffeine from coffee fruit extract, sweetened only with raw honey."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "20g" },
        { "type": "text", "id": "label", "label": "Label", "default": "Protein" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Complete protein from whey concentrate and milk protein isolate." }
      ]
    }
  ],
  "presets": [{
    "name": "Value Props",
    "blocks": [
      { "type": "stat", "settings": { "number": "20g", "label": "Protein", "description": "Complete protein from whey concentrate and milk protein isolate. No collagen fillers, no plant blends." } },
      { "type": "stat", "settings": { "number": "100mg", "label": "Caffeine", "description": "Natural caffeine from real coffee and coffee fruit extract. Smooth, sustained energy without the crash." } },
      { "type": "stat", "settings": { "number": "Honey", "label": "Sweetened", "description": "Raw unfiltered honey and date syrup. No sugar alcohols, no stevia, no sucralose. Just real sweetness." } }
    ]
  }]
}
{% endschema %}
