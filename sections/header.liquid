<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo">BOLD <span>BAR</span></a>
    <ul class="nav-links">
      <li><a href="#shop">Shop</a></li>
      <li><a href="#ingredients">Ingredients</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#faq">FAQ</a></li>
    </ul>
    <div class="header-right">
      <a href="/cart" class="cart-btn" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span id="cart-count">{{ cart.item_count }}</span>
      </a>
      <button class="btn-preorder" onclick="addToCart(this)">Preorder Now</button>
      <button class="hamburger" aria-label="Menu" onclick="document.querySelector('.mobile-nav').classList.add('open')">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav">
  <button class="close-btn" onclick="this.parentElement.classList.remove('open')">&times;</button>
  <a href="#shop" onclick="this.parentElement.classList.remove('open')">Shop</a>
  <a href="#ingredients" onclick="this.parentElement.classList.remove('open')">Ingredients</a>
  <a href="#about" onclick="this.parentElement.classList.remove('open')">About</a>
  <a href="#faq" onclick="this.parentElement.classList.remove('open')">FAQ</a>
</div>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
