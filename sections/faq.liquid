<section class="faq" id="faq">
  <div class="faq-grid">
    <div class="faq-intro rv">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <form class="faq-email-form" onsubmit="event.preventDefault();">
        <input type="email" placeholder="your@email.com">
        <button type="submit">Send</button>
      </form>
    </div>
    <div class="faq-list rv d1">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-q" onclick="toggleFaq(this)">{{ block.settings.question }} <span class="faq-icon">+</span></button>
          <div class="faq-a"><p>{{ block.settings.answer }}</p></div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions? We Have Answers." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Can't find what you're looking for? Drop us a line and we will get back to you within 24 hours." }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ",
    "blocks": [
      { "type": "question", "settings": { "question": "What is Bold Bar?", "answer": "Bold Bar is a performance protein bar made with 12 real-food ingredients. Each bar delivers 20g of complete protein and 100mg of natural caffeine from coffee and coffee fruit extract, sweetened only with raw honey and date syrup." } },
      { "type": "question", "settings": { "question": "How much caffeine is in each bar?", "answer": "Each bar contains 100mg of natural caffeine, roughly equivalent to a strong cup of coffee. The caffeine comes from real coffee and coffee fruit extract for smooth, sustained energy." } },
      { "type": "question", "settings": { "question": "What sweetener do you use?", "answer": "We use raw unfiltered honey and date syrup. No sugar alcohols, no stevia, no sucralose, and no artificial sweeteners of any kind." } },
      { "type": "question", "settings": { "question": "Is it Kosher?", "answer": "Yes. Bold Bar is OUD Kosher certified and gluten free." } },
      { "type": "question", "settings": { "question": "When does it ship?", "answer": "Preorders ship Q2 2025. You will receive a tracking notification as soon as your order is on its way. Free shipping on all orders over $50." } },
      { "type": "question", "settings": { "question": "What about allergens?", "answer": "Bold Bar contains tree nuts (almonds), milk, and wheat-adjacent ingredients (dairy protein crisps). It is certified gluten free. Manufactured in a facility that also processes peanuts, soy, and eggs." } }
    ]
  }]
}
{% endschema %}
